# ── Stage 1: Install all deps & build ────────────────────────────────
FROM node:20-slim AS build

WORKDIR /app

# Copy workspace root manifests
COPY package.json yarn.lock ./
COPY orderly-dashboard-FE/package.json orderly-dashboard-FE/package.json

# Install all dependencies (including devDependencies for build)
RUN yarn --frozen-lockfile

# Copy FE source
COPY orderly-dashboard-FE/ orderly-dashboard-FE/

# Build (UnoCSS + Remix/Vite)
RUN yarn workspace orderly-dashboard-fe build

# ── Stage 2: Production runtime ──────────────────────────────────────
FROM node:20-slim AS production

WORKDIR /app

# Copy workspace root manifests
COPY package.json yarn.lock ./
COPY orderly-dashboard-FE/package.json orderly-dashboard-FE/package.json

# Install production dependencies only
RUN yarn --frozen-lockfile --production

# Copy build output and server
COPY --from=build /app/orderly-dashboard-FE/build orderly-dashboard-FE/build
COPY orderly-dashboard-FE/server.js orderly-dashboard-FE/server.js

WORKDIR /app/orderly-dashboard-FE

EXPOSE 3000

CMD ["node", "server.js"]
